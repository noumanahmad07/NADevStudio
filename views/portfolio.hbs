{{> nav}}
<main id="main-content" class="inner-page">
  <div class="section-inner">
    <div class="section-header">
      <div class="section-eyebrow reveal">Our Portfolio</div>
      <h1 class="section-title reveal reveal-delay-1">Web &amp; Mobile Projects We Have Built</h1>
      <p class="section-sub reveal reveal-delay-2">Real products for real businesses — e-commerce marketplaces, mobile apps, analytics dashboards, and POS systems delivered for clients in Pakistan and worldwide.</p>
    </div>

    <div class="case-studies">
      <article class="case-study reveal">
        <div class="case-study-media">
          <img
            src="/images/portfolio/port-shopflow.webp"
            alt="ShopFlow multi-vendor e-commerce marketplace dashboard"
            width="800"
            height="533"
            loading="lazy"
            decoding="async"
          >
        </div>
        <div class="case-study-content">
          <div class="port-cat">E-Commerce · Web App</div>
          <h2>ShopFlow — Multi-Vendor Marketplace</h2>
          <p>A full-featured B2C marketplace connecting buyers with multiple vendors. Built for scale with real-time inventory sync, Stripe payments, and separate vendor dashboards.</p>
          <div class="case-study-meta">
            <div>
              <h3>Challenge</h3>
              <p>The client needed a marketplace that could handle 10k+ daily users, multiple payment methods, and vendor self-service without manual admin work.</p>
            </div>
            <div>
              <h3>Solution</h3>
              <p>Custom Next.js frontend with Node.js API, PostgreSQL database, Redis caching, and Stripe Connect for split payments between platform and vendors.</p>
            </div>
            <div>
              <h3>Results</h3>
              <p>10k+ daily active users, sub-2s page loads, 40% increase in vendor onboarding after dashboard launch.</p>
            </div>
          </div>
          <div class="service-tags">
            <span class="service-tag">Next.js</span>
            <span class="service-tag">Node.js</span>
            <span class="service-tag">PostgreSQL</span>
            <span class="service-tag">Stripe</span>
          </div>
        </div>
      </article>

      <article class="case-study reveal">
        <div class="case-study-media">
          <img
            src="/images/portfolio/port-healthtrack.webp"
            alt="HealthTrack Pro fitness and nutrition mobile app"
            width="800"
            height="533"
            loading="lazy"
            decoding="async"
          >
        </div>
        <div class="case-study-content">
          <div class="port-cat">Mobile App · iOS &amp; Android</div>
          <h2>HealthTrack Pro</h2>
          <p>A fitness and nutrition tracking app with AI-powered meal suggestions, workout logging, and progress analytics for health-conscious users.</p>
          <div class="case-study-meta">
            <div>
              <h3>Challenge</h3>
              <p>Build a cross-platform app with offline support, wearable integration, and personalized recommendations that keep users engaged daily.</p>
            </div>
            <div>
              <h3>Solution</h3>
              <p>React Native app with Firebase backend, custom ML pipeline for meal suggestions, and Apple Health / Google Fit sync.</p>
            </div>
            <div>
              <h3>Results</h3>
              <p>4.8★ App Store rating, 15k+ downloads in first 3 months, 62% weekly retention rate.</p>
            </div>
          </div>
          <div class="service-tags">
            <span class="service-tag">React Native</span>
            <span class="service-tag">Firebase</span>
            <span class="service-tag">AI/ML</span>
          </div>
        </div>
      </article>

      <article class="case-study reveal">
        <div class="case-study-media">
          <img
            src="/images/portfolio/port-datalens.webp"
            alt="DataLens Analytics business intelligence dashboard"
            width="800"
            height="533"
            loading="lazy"
            decoding="async"
          >
        </div>
        <div class="case-study-content">
          <div class="port-cat">SaaS · Analytics Platform</div>
          <h2>DataLens Analytics</h2>
          <p>Real-time business intelligence dashboard for SMEs — connect data sources, visualize KPIs, and export reports without a data science team.</p>
          <div class="case-study-meta">
            <div>
              <h3>Challenge</h3>
              <p>SME owners needed actionable insights from scattered spreadsheets and accounting tools without expensive enterprise BI software.</p>
            </div>
            <div>
              <h3>Solution</h3>
              <p>React dashboard with WebSocket live updates, drag-and-drop chart builder, and integrations with QuickBooks and Google Sheets.</p>
            </div>
            <div>
              <h3>Results</h3>
              <p>Reduced reporting time from 4 hours to 15 minutes per week for pilot clients.</p>
            </div>
          </div>
          <div class="service-tags">
            <span class="service-tag">React</span>
            <span class="service-tag">WebSockets</span>
            <span class="service-tag">Chart.js</span>
          </div>
        </div>
      </article>

      <article class="case-study reveal">
        <div class="case-study-media">
          <img
            src="/images/portfolio/port-orderease.webp"
            alt="OrderEase restaurant point-of-sale tablet app"
            width="800"
            height="533"
            loading="lazy"
            decoding="async"
          >
        </div>
        <div class="case-study-content">
          <div class="port-cat">Mobile · Restaurant Tech</div>
          <h2>OrderEase POS App</h2>
          <p>Tablet-based point-of-sale and kitchen display system for restaurants — table management, order routing, and daily sales reports in one app.</p>
          <div class="case-study-meta">
            <div>
              <h3>Challenge</h3>
              <p>Local restaurants needed an affordable POS that works offline during internet outages and syncs when connectivity returns.</p>
            </div>
            <div>
              <h3>Solution</h3>
              <p>Flutter tablet app with offline-first SQLite storage, Bluetooth receipt printing, and cloud sync for multi-location chains.</p>
            </div>
            <div>
              <h3>Results</h3>
              <p>Deployed across 12 restaurant locations, 30% faster order processing vs. previous paper-based system.</p>
            </div>
          </div>
          <div class="service-tags">
            <span class="service-tag">Flutter</span>
            <span class="service-tag">SQLite</span>
            <span class="service-tag">Offline-First</span>
          </div>
        </div>
      </article>
    </div>

    <div class="page-cta reveal">
      <h2>Want results like these?</h2>
      <p>Share your idea and we will outline scope, timeline, and budget within 24 hours.</p>
      <div class="cta-buttons">
        <a href="/contact" class="btn btn-primary btn-lg">Start Your Project</a>
        <a href="/services" class="btn btn-outline btn-lg">Explore Services</a>
      </div>
    </div>
  </div>
</main>
{{> footer}}
